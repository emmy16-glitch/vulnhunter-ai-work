        "search"
      ],
      "denied_operations": [
        "git-push",
        "deploy",
        "delete"
      ],
      "write_access": false,
      "network_access": false,
      "connector_access": false,
      "secrets_access": false
    },
    {
      "tool_id": "test.runner",
      "purpose": "Run approved local verification commands.",
      "allowed_operations": [
        "run-focused",
        "run-regression"
      ],
      "denied_operations": [
        "git-push",
        "deploy",
        "delete"
      ],
      "write_access": false,
      "network_access": false,
      "connector_access": false,
      "secrets_access": false
    }
  ],
  "data_permissions": [
    {
