{
  "schema_version": "1.0",
  "runtime_id": "vulnhunter-bounded-agent",
  "max_controller_iterations": 25,
  "global_denied_actions": [
    "authorization.override",
    "connector.enable",
    "deployment.execute",
    "git.push",
    "review.self_approve",
    "secrets.read"
  ],
  "require_hash_chained_audit": true,
  "connectors_enabled": false,
  "unrestricted_shell_enabled": false,
  "public_scanning_enabled": false
}
