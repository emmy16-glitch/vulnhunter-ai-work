{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vulnhunter.local/schema/role-definition-1.0.json",
  "title": "VulnHunter Role Definition",
  "type": "object",
  "required": [
    "schema_version",
    "role_id",
    "display_name",
    "owner",
    "version",
    "purpose",
    "risk_level",
    "status",
    "trust_assumption",
    "allowed_inputs",
    "allowed_actions",
    "denied_actions",
    "skill_ids",
    "tools",
    "data_permissions",
    "output_schema",
    "verification_requirements",
    "human_approval_points",
    "required_tests",
    "last_reviewed_on",
    "rollback_procedure",
    "connector_policy",
    "external_dependencies"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "role_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9.-]{1,63}$"},
    "display_name": {"type": "string", "minLength": 3},
    "owner": {"type": "string", "minLength": 3},
    "version": {"type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"},
    "purpose": {"type": "string", "minLength": 20},
    "risk_level": {"enum": ["low", "medium", "high", "critical"]},
    "status": {"enum": ["planned", "active", "disabled", "deprecated"]},
    "trust_assumption": {"const": "untrusted"},
    "allowed_inputs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "allowed_actions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "denied_actions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "skill_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "tools": {"type": "array"},
    "data_permissions": {"type": "array"},
    "output_schema": {"type": "object"},
    "verification_requirements": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "human_approval_points": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "required_tests": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "last_reviewed_on": {"type": "string", "format": "date"},
    "rollback_procedure": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "connector_policy": {"type": "object"},
    "external_dependencies": {"type": "array"}
  },
  "additionalProperties": false
}
