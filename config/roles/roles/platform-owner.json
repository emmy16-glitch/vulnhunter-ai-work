{
  "schema_version": "1.0",
  "owner": "Emmanuel Okunlola",
  "version": "1.0.0",
  "status": "planned",
  "trust_assumption": "untrusted",
  "allowed_inputs": [
    "approved action manifest",
    "verified authorization evidence",
    "redacted evidence"
  ],
  "denied_actions": [
    "authorization.override",
    "connector.enable",
    "data.delete",
    "deployment.execute",
    "git.push",
    "review.self_approve",
    "secrets.read"
  ],
  "data_permissions": [
    {
      "resource": "governed-security-operations",
      "classification": "sensitive",
      "operations": [
        "read"
      ],
      "purpose": "Perform the declared role using approved evidence.",
      "retention": "No independent copy by default."
    }
  ],
  "output_schema": {
    "type": "object",
    "required": [
      "role_id",
      "verdict",
      "evidence",
      "limitations"
    ],
    "properties": {
      "role_id": {
        "type": "string"
      },
      "verdict": {
        "type": "string"
      },
      "evidence": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "limitations": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "additionalProperties": false
  },
  "verification_requirements": [
    "Verify the exact action manifest and authorization evidence.",
    "Stop on scope, policy, approval, integrity, or redaction failure.",
    "Record limitations and independent verification requirements."
  ],
  "required_tests": [
    "Role schema validation.",
    "Denied-action decision test.",
    "Approval and exact-action binding test."
  ],
  "last_reviewed_on": "2026-07-11",
  "rollback_procedure": [
    "Disable the role definition.",
    "Revert the registry commit.",
    "Re-run registry and project verification."
  ],
  "connector_policy": {
    "default": "disabled",
    "grants": []
  },
  "external_dependencies": [],
  "role_id": "platform-owner",
  "display_name": "VulnHunter Platform Owner",
  "purpose": "Govern break-glass activation, reauthentication, and short-lived privilege grants without storing sudo credentials.",
  "risk_level": "critical",
  "allowed_actions": [
    "approval.read",
    "approval.decide",
    "privilege.request",
    "privilege.revoke",
    "settings.manage"
  ],
  "skill_ids": [
    "privileged-broker-governance"
  ],
  "tools": [
    {
      "tool_id": "privileged-broker.contract",
      "purpose": "Issue exact-action-bound broker requests.",
      "allowed_operations": [
        "request",
        "revoke",
        "inspect"
      ],
      "denied_operations": [
        "arbitrary-shell",
        "password-store",
        "scope-bypass"
      ],
      "write_access": true,
      "network_access": false,
      "connector_access": false,
      "secrets_access": false
    }
  ]
}
