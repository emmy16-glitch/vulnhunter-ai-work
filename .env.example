# Example only. Generate a unique secret at deployment; never commit its value.
VULNHUNTER_WEB_SECRET_KEY=REPLACE_WITH_A_UNIQUE_RANDOM_SECRET
VULNHUNTER_WEB_DEBUG=false
VULNHUNTER_WEB_HTTPS=true
VULNHUNTER_WEB_ALLOWED_HOSTS=vulnhunter.example.test
VULNHUNTER_WEB_CSRF_TRUSTED_ORIGINS=https://vulnhunter.example.test

# Enable only behind a trusted reverse proxy that strips client-supplied
# X-Forwarded-* headers and sets X-Forwarded-Proto itself.
VULNHUNTER_WEB_TRUST_PROXY=false
VULNHUNTER_WEB_HSTS_SECONDS=3600
VULNHUNTER_WEB_HSTS_INCLUDE_SUBDOMAINS=false
VULNHUNTER_WEB_LOG_LEVEL=INFO

# Persistent paths. Mount and back these up according to the deployment plan.
VULNHUNTER_WEB_DATABASE=/srv/vulnhunter/state/vulnhunter-web.sqlite3
VULNHUNTER_WEB_STATIC_ROOT=/srv/vulnhunter/static
VULNHUNTER_WEB_MEDIA_ROOT=/srv/vulnhunter/evidence/media
VULNHUNTER_WEB_DATABASE_ENGINE=postgresql
VULNHUNTER_POSTGRES_DATABASE=vulnhunter
VULNHUNTER_POSTGRES_USER=vulnhunter
VULNHUNTER_POSTGRES_PASSWORD=INJECT_FROM_SECRET_MANAGER
VULNHUNTER_POSTGRES_HOST=127.0.0.1
VULNHUNTER_POSTGRES_PORT=5432
VULNHUNTER_POSTGRES_SSLMODE=require
VULNHUNTER_POSTGRES_CONN_MAX_AGE=60
VULNHUNTER_AUTHORIZATION_DATABASE=/srv/vulnhunter/state/authorizations.db
VULNHUNTER_GOVERNANCE_DATABASE=/srv/vulnhunter/state/governance.db
VULNHUNTER_AGENT_DATABASE=/srv/vulnhunter/state/agent.db
VULNHUNTER_APPROVAL_DATABASE=/srv/vulnhunter/state/approvals.sqlite3
VULNHUNTER_AGENT_ACTIVITY_ROOT=/srv/vulnhunter/evidence/agent-activity
VULNHUNTER_SECURITY_EVIDENCE_ROOT=/srv/vulnhunter/evidence/security-tools
VULNHUNTER_TASK_GRAPH_ROOT=/srv/vulnhunter/state/task-graphs
VULNHUNTER_MOBILE_ARTIFACT_ROOT=/srv/vulnhunter/evidence/mobile-artifacts
VULNHUNTER_MOBILE_MAX_APK_BYTES=1000000000

# External tools remain registered but execution stays controlled by the
# reviewed config/security_tools/runtime.json activation gate.
VULNHUNTER_TOOLS_ROOT=/mnt/vulnhunter-data/tools/vulnhunter-external

# Advisory components. These settings never authorize execution. Graphify, Groq,
# MCP, and deterministic verification keep independent governance gates.
VULNHUNTER_GRAPHIFY_EXECUTABLE=/mnt/vulnhunter-data/tools/uv/tool-bin/graphify
VULNHUNTER_GRAPHIFY_OUTPUT_ROOT=/srv/vulnhunter/state/repository-graph
VULNHUNTER_GRAPHIFY_EXECUTION_ENABLED=false

VULNHUNTER_GUNICORN_BIND=127.0.0.1:8002
VULNHUNTER_GUNICORN_WORKERS=1
VULNHUNTER_GUNICORN_THREADS=1
VULNHUNTER_GUNICORN_TIMEOUT=60

# GroqCloud advisory inference. Store the key in an owner-only file; do not put
# the key value in this environment file. Enable only after the controlled
# activation script verifies model inventory, privacy gating and one harmless
# structured response.
VULNHUNTER_GROQ_ENABLED=false
VULNHUNTER_GROQ_API_BASE=https://api.groq.com/openai/v1
VULNHUNTER_GROQ_API_KEY_FILE=/home/vulnhunter/.groq-api-key
VULNHUNTER_GROQ_MODEL=openai/gpt-oss-120b
VULNHUNTER_GROQ_FALLBACK_MODEL=openai/gpt-oss-20b
VULNHUNTER_GROQ_TIMEOUT_SECONDS=90
VULNHUNTER_GROQ_MAX_INPUT_BYTES=24000
VULNHUNTER_GROQ_MAX_OUTPUT_TOKENS=1200
