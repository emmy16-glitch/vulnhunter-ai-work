FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /opt/vulnhunter
COPY pyproject.toml README.md ./
COPY vulnhunter ./vulnhunter
COPY config/security_tools ./config/security_tools
RUN python -m pip install --no-cache-dir .

USER 65532:65532
ENTRYPOINT ["python", "-m", "vulnhunter.security_tools.scanner_worker"]
