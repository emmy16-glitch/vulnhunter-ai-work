{
  "schema_version": "1.0",
  "role_id": "independent-security-verifier",
  "display_name": "Independent Security Verifier",
  "owner": "Emmanuel Okunlola",
  "version": "1.0.0",
  "purpose": "Verify security properties independently from implementers and report unsupported claims or blockers.",
  "risk_level": "critical",
